# Octane LLM proxy credentials.
# Generate a key at https://tools.ai-dev.octane.co/portal and paste it below.
OCTANE_LITELLM=https://llm.ai-dev.octane.co
OCTANE_API_KEY=

# NVIDIA NIM credentials.
# Generate a key at https://developer.nvidia.com/nim and paste it below.
NVIDIA_NIM_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=

# Optional: override upload/output directories.
# Defaults to ./uploads and ./outputs inside the backend folder.
# UPLOADS_DIR=
# OUTPUTS_DIR=
