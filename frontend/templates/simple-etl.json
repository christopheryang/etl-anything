{
  "id": "simple-etl",
  "name": "Simple ETL Pipeline",
  "description": "Basic Extract-Transform-Load workflow: read a file, transform with AI, save output. Great starting point for any data processing task.",
  "category": "ETL",
  "tags": ["etl", "beginner", "file-processing"],
