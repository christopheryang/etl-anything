# Optional overrides. The defaults below match the standard repo layout
# (frontend/ and backend/ as siblings) and the workshop's default ports —
# you only need a .env.local if you want to change them.

# URL of the FastAPI backend.
# FastAPI backend URL
FASTAPI_URL=http://localhost:8001

# Path to the backend's uploads directory. Must match the backend's UPLOADS_DIR.
# Default: ../backend/uploads (resolved from the frontend/ working directory)
# UPLOADS_DIR=../backend/uploads
